{
    "title": "Home Row Mods (英語入力モード限定)",
    "rules": [
        {
            "description": "Home Row Mods (左手: ASDF = Ctrl+Shift+Alt+Cmd) - 英語入力時のみ",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "a",
                        "modifiers": {
                            "optional": ["any"]
                        }
                    },
                    "conditions": [
                        {
                            "type": "input_source_if",
                            "input_sources": [
                                {
                                    "language": "en"
                                }
                            ]
                        }
                    ],
                    "to": [
                        {
                            "key_code": "left_control"
                        }
                    ],
                    "to_if_alone": [
                        {
                            "key_code": "a"
                        }
                    ],
                    "parameters": {
                        "basic.to_if_alone_timeout_milliseconds": 175,
                        "basic.to_if_held_down_threshold_milliseconds": 75
                    }
