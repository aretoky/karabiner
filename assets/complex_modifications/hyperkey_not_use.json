{
  "title": "Change § key to Hyper Key",
  "rules": [
    {
      "description": "Change § key to Hyper Key (⌘+⌥+⌃+⇧)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "non_us_backslash",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to_if_held_down": [
            {
              "key_code": "right_command",
              "modifiers": ["right_control", "right_option", "right_shift"]
            }
          ],
          "to_if_alone": [
            {
              "key_code": "spacebar"
            }
          ]
        }
      ]
    }
  ]
}
