{
  "title": "Space Number Layer",
  "rules": [
    {
      "description": "スペース数字レイヤー: セミコロンShift",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "semicolon",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "left_shift"
            },
            {
              "set_variable": {
                "name": "space_shift",
                "value": 1
              }
            }
          ],
          "to_if_alone": [
            {
              "key_code": "0"
            },
            {
              "set_variable": {
                "name": "space_shift",
                "value": 0
              }
            }
          ],
          "to_delayed_action": {
            "to_if_invoked": [
              {
                "set_variable": {
                  "name": "space_shift",
                  "value": 0
                }
              }
            ],
            "to_if_canceled": [
              {
                "set_variable": {
                  "name": "space_shift",
                  "value": 0
                }
              }
            ]
          },
          "conditions": [
            {
              "type": "variable_if",
              "name": "space_layer",
              "value": 1
            }
          ],
          "parameters": {
            "basic.to_if_alone_timeout_milliseconds": 200,
            "basic.to_delayed_action_delay_milliseconds": 1000
          }
        }
      ]
    },
