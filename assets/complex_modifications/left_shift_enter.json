{
  "title": "Left Shift to Enter",
  "rules": [
    {
      "description": "左シフト単独タップでEnter（100ms以内）、ホールドでShift",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "left_shift",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to_if_alone": [
            {
              "key_code": "return_or_enter"
            }
          ],
          "to_if_held_down": [
            {
              "key_code": "left_shift"
            }
          ],
          "parameters": {
            "basic.to_if_alone_timeout_milliseconds": 100,
            "basic.to_if_held_down_threshold_milliseconds": 75
          }
        }
      ]
    }
  ]
}
