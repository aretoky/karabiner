            "key_code": "e",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "escape"
            },
            {
              "key_code": "japanese_eisuu"
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "eisuu",
              "value": 1
            }
          ]
        },
	{
          "type": "basic",
